{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // If you can't debug in VSCode, try adding this to the list below
            // "sourceMaps": true
            "args": [
                "--timeout",
                "999999",
                "--colors",
                "--recursive",
                "${workspaceFolder}/tests/unit/**/*.ts",
                "--check-leaks",
                "-r",
                "${workspaceFolder}/tests/unit/TestInit.js",
                "-r",
                "ts-node/register",
                "-r",
                "tsconfig-paths/register"
            ],
            "internalConsoleOptions": "neverOpen",
            "name": "Mocha Tests",
            "program": "${workspaceFolder}/node_modules/mocha/bin/_mocha",
            "request": "launch",
            "skipFiles": ["<node_internals>/**"],
            "type": "node",
            "console": "integratedTerminal"
        },
        {
            "name": "Playwright: Current File (headed)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
            "args": ["test", "${file}", "--project=chromium", "--headed"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Playwright: Current File (PWDEBUG)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
            "args": ["test", "${file}", "--project=chromium", "--headed"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PWDEBUG": "1"
            },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Playwright: Test at Cursor (PWDEBUG)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
            "args": ["test", "${file}", "--project=chromium", "--headed", "-g", "${selectedText}"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PWDEBUG": "1"
            },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "https://localhost.quizbowlreader.com:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Launch Edge",
            "request": "launch",
            "type": "pwa-msedge",
            "url": "https://localhost.quizbowlreader.com:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
